{
  "name": "sistema-mvc-exam",
  "private": true,
  "version": "1.0.0",
  "main": "../electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"cross-env NODE_ENV=development electron ../electron/main.js\"",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:preview": "cross-env NODE_ENV=production electron ../electron/main.js"
  },
  "build": {
    "appId": "com.sistemamvc.exam",
    "productName": "SistemaMVC Examen",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "dist/**",
      "../electron/**",
      "!../electron/node_modules"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-winstaller", "app-builder-bin", "7zip-bin"]
  }
}
